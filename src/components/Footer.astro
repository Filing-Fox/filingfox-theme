---
import type { SiteConfig } from "../lib/site-config";
interface Props { site: SiteConfig; }
const { site } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="brand-col">
      <a href="/" class="footer-brand">
        <img src={site.brand.logo} alt={site.siteName} class="footer-logo" />
      </a>
      <p class="muted small">{site.tagline}</p>
      <address class="muted small">
        {site.address.line1}{site.address.line2 ? `, ${site.address.line2}` : ""}<br />
        {site.address.city}, {site.address.region} {site.address.postalCode}<br />
        {site.address.country}
      </address>
    </div>
    <div>
      <h4>Shop</h4>
      <ul>
        <li><a href="/products">All Products</a></li>
        <li><a href="/products">New Arrivals</a></li>
        <li><a href="/cart">Cart</a></li>
      </ul>
    </div>
    <div>
      <h4>Customer Care</h4>
      <ul>
        <li><a href="/shipping">Shipping</a></li>
        <li><a href="/returns">Returns & Refunds</a></li>
        <li><a href="/contact">Contact Us</a></li>
        <li><a href={`mailto:${site.email}`}>Order Help</a></li>
      </ul>
    </div>
    <div>
      <h4>Company</h4>
      <ul>
        <li><a href="/about">About {site.siteName}</a></li>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms of Service</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <span class="muted small">© {year} {site.legal?.companyName ?? site.siteName}. All rights reserved.</span>
    <span class="muted small">Secure SSL · 256-bit encryption</span>
  </div>
</footer>
<style>
  .site-footer {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    padding: 3.5rem 0 0;
  }
  .footer-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    padding-bottom: 2.5rem;
  }
  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .brand-col { grid-column: 1 / -1; }
  }
  .footer-brand { display: inline-block; margin-bottom: 0.75rem; }
  .footer-logo {
    background: var(--color-primary);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius);
    height: 44px;
    width: auto;
    max-width: 200px;
    object-fit: contain;
  }
  .site-footer h4 {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg);
    font-weight: 700;
  }
  .site-footer ul { list-style: none; padding: 0; margin: 0; }
  .site-footer ul li { margin-bottom: 0.55rem; }
  .site-footer a {
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color 0.15s;
    word-break: break-word;
  }
  .site-footer a:hover { color: var(--color-fg); }
  address { font-style: normal; }
  .small { font-size: 0.85rem; line-height: 1.55; }
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
