---
import type { SiteConfig } from "../lib/site-config";
interface Props { site: SiteConfig; }
const { site } = Astro.props;
---
<aside class="cart-drawer" data-cart-drawer aria-label="Shopping cart" style="display:none">
  <div class="cart-backdrop" data-cart-close></div>
  <div class="cart-panel" role="dialog" aria-modal="true" aria-labelledby="cart-title">
    <header class="cart-head">
      <h2 id="cart-title">Your Cart</h2>
      <button type="button" class="cart-close" data-cart-close aria-label="Close cart">×</button>
    </header>
    <p class="cart-empty muted" data-cart-empty>Your cart is empty.</p>
    <div class="cart-body" data-cart-body style="display:none">
      <ul class="cart-lines" data-cart-lines data-cart-line-template="#tpl-cart-line"></ul>
      <footer class="cart-foot">
        <div class="subtotal-row">
          <span>Subtotal</span>
          <span class="subtotal" data-cart-subtotal>—</span>
        </div>
        <a href="/checkout" class="btn btn-primary cart-checkout">Checkout</a>
        <button type="button" class="btn btn-outline" data-cart-close>Continue Shopping</button>
      </footer>
    </div>
  </div>
</aside>

<template id="tpl-cart-line">
  <li class="cart-line">
    <img data-cart-slot="image" alt="" width="64" height="64" />
    <div class="line-info">
      <a class="line-name" data-cart-slot="name"></a>
      <span class="muted small" data-cart-slot="sku"></span>
      <div class="line-qty">
        <button type="button" data-cart-slot="dec" aria-label="Decrease">−</button>
        <span data-cart-slot="qty"></span>
        <button type="button" data-cart-slot="inc" aria-label="Increase">+</button>
      </div>
    </div>
    <div class="line-end">
      <span class="line-price" data-cart-slot="price"></span>
      <button type="button" class="line-remove" data-cart-slot="remove">Remove</button>
    </div>
  </li>
</template>

<style>
  .cart-drawer { position: fixed; inset: 0; z-index: 100; }
  .cart-backdrop { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.45); }
  .cart-panel {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: min(420px, 100vw);
    background: white;
    display: flex; flex-direction: column;
    box-shadow: -12px 0 24px rgba(0, 0, 0, 0.15);
  }
  .cart-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem; border-bottom: 1px solid var(--color-border);
  }
  .cart-head h2 { margin: 0; font-size: 1.15rem; }
  .cart-close {
    background: none; border: 0; font-size: 1.75rem; line-height: 1;
    cursor: pointer; color: var(--color-fg-muted);
  }
  .cart-close:hover { color: var(--color-fg); }
  .cart-empty { padding: 2rem 1.25rem; }
  .cart-body { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
  .cart-lines { list-style: none; margin: 0; padding: 0; overflow-y: auto; flex: 1; }
  .cart-line {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 0.85rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .cart-line img { border-radius: var(--radius); object-fit: cover; aspect-ratio: 1; }
  .line-info { display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
  .line-name { font-weight: 600; color: var(--color-fg); text-decoration: none; }
  .small { font-size: 0.8rem; }
  .line-qty {
    display: inline-flex; align-items: center; gap: 0.5rem;
    margin-top: 0.35rem;
  }
  .line-qty button {
    background: var(--color-bg-alt); border: 1px solid var(--color-border);
    width: 26px; height: 26px; border-radius: 6px; cursor: pointer;
  }
  .line-end { display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; }
  .line-price { font-weight: 600; }
  .line-remove { background: none; border: 0; color: var(--color-danger); font-size: 0.8rem; padding: 0; cursor: pointer; }
  .cart-foot { padding: 1.25rem; border-top: 1px solid var(--color-border); display: grid; gap: 0.75rem; }
  .subtotal-row { display: flex; justify-content: space-between; font-weight: 600; font-size: 1.1rem; }
  .cart-checkout { width: 100%; }
</style>
