---
import type { Product } from "../lib/select-products";
import type { Currency } from "../lib/site-config";
import { currencyFormatter } from "../lib/site-config";

interface Props {
  product: Product;
  currency: Currency;
}
const { product, currency } = Astro.props;
const fmt = currencyFormatter(currency);
const onSale = product.compareAtPrice && product.compareAtPrice > product.price;
const productJson = JSON.stringify({
  slug: product.slug,
  name: product.name,
  sku: product.sku,
  price: product.price,
  image: product.images[0],
});
---
<article class="product-card card" x-data>
  <a class="product-image" href={`/products/${product.slug}`} aria-label={product.name}>
    <img src={product.images[0]} alt={product.name} loading="lazy" decoding="async" width="400" height="400" />
    {onSale && <span class="sale-tag">Sale</span>}
  </a>
  <div class="product-body">
    <a class="product-name" href={`/products/${product.slug}`}>{product.name}</a>
    <div class="price-row">
      <span class="price">{fmt.format(product.price)}</span>
      {onSale && product.compareAtPrice && <span class="strike">{fmt.format(product.compareAtPrice)}</span>}
    </div>
    <button
      type="button"
      class="btn btn-primary add-btn"
      data-product={productJson}
      @click={`$store.cart.add(JSON.parse($el.dataset.product), 1)`}
    >
      Add to Cart
    </button>
  </div>
</article>
<style>
  .product-card { display: flex; flex-direction: column; }
  .product-image { display: block; position: relative; aspect-ratio: 1 / 1; overflow: hidden; background: var(--color-bg-alt); }
  .product-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .product-image:hover img { transform: scale(1.04); }
  .sale-tag {
    position: absolute; top: 0.6rem; left: 0.6rem;
    background: var(--color-danger); color: white;
    font-size: 0.75rem; font-weight: 600;
    padding: 0.2rem 0.55rem; border-radius: 999px;
  }
  .product-body { padding: 0.9rem 0.95rem 1.1rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .product-name {
    color: var(--color-fg); text-decoration: none; font-weight: 600;
    line-height: 1.3; min-height: 2.6em;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .price-row { display: flex; gap: 0.5rem; align-items: baseline; }
  .price { font-weight: 700; font-size: 1.05rem; }
  .add-btn { margin-top: auto; }
</style>
