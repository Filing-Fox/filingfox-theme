---
import type { SiteConfig } from "../lib/site-config";
interface Props { site: SiteConfig; }
const { site } = Astro.props;
---
<section class="section">
  <div class="container" x-data>
    <h1>Your Cart</h1>
    <template x-if="$store.cart.items.length === 0">
      <div class="empty">
        <p class="muted">Your cart is empty.</p>
        <a class="btn btn-primary" href="/products">Continue Shopping</a>
      </div>
    </template>
    <template x-if="$store.cart.items.length > 0">
      <div class="cart-page">
        <ul class="lines">
          <template x-for="item in $store.cart.items" :key="item.slug">
            <li class="line">
              <img :src="item.image" :alt="item.name" width="100" height="100" />
              <div class="info">
                <a class="name" :href="`/products/${item.slug}`" x-text="item.name"></a>
                <span class="muted small" x-text="`SKU ${item.sku}`"></span>
                <span class="muted small" x-text="$store.cart.format(item.price) + ' each'"></span>
              </div>
              <div class="qty">
                <button type="button" @click="$store.cart.setQty(item.slug, item.qty - 1)" aria-label="Decrease">−</button>
                <input type="number" min="0" max="99" :value="item.qty" @change="$store.cart.setQty(item.slug, parseInt($event.target.value, 10))" />
                <button type="button" @click="$store.cart.setQty(item.slug, item.qty + 1)" aria-label="Increase">+</button>
              </div>
              <div class="end">
                <span class="line-total" x-text="$store.cart.format(item.price * item.qty)"></span>
                <button type="button" class="remove" @click="$store.cart.remove(item.slug)">Remove</button>
              </div>
            </li>
          </template>
        </ul>
        <aside class="cart-side card">
          <h2>Summary</h2>
          <div class="totals">
            <div class="row"><span>Subtotal</span><span x-text="$store.cart.format($store.cart.subtotal)"></span></div>
            <div class="row total"><span>Total</span><span x-text="$store.cart.format($store.cart.subtotal)"></span></div>
          </div>
          <a class="btn btn-primary checkout" href="/checkout">Proceed to Checkout</a>
          <a class="btn btn-outline" href="/products">Continue Shopping</a>
        </aside>
      </div>
    </template>
  </div>
</section>
<style>
  .empty { text-align: center; padding: 4rem 0; display: grid; gap: 1.25rem; justify-items: center; }
  .cart-page { display: grid; gap: 2rem; grid-template-columns: 1fr; }
  @media (min-width: 900px) { .cart-page { grid-template-columns: 1.5fr 1fr; align-items: start; } }
  .lines { list-style: none; padding: 0; margin: 0; }
  .line {
    display: grid; grid-template-columns: 100px 1fr auto auto;
    gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--color-border);
    align-items: center;
  }
  @media (max-width: 700px) {
    .line { grid-template-columns: 80px 1fr; grid-template-rows: auto auto; }
    .qty, .end { grid-column: 2; }
  }
  .line img { border-radius: var(--radius); object-fit: cover; aspect-ratio: 1; }
  .info { display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
  .name { font-weight: 600; color: var(--color-fg); text-decoration: none; }
  .small { font-size: 0.85rem; }
  .qty { display: inline-flex; align-items: center; gap: 0.4rem; }
  .qty input { width: 50px; text-align: center; padding: 0.4rem; border: 1px solid var(--color-border); border-radius: var(--radius); }
  .qty button { width: 30px; height: 30px; border-radius: 6px; background: var(--color-bg-alt); border: 1px solid var(--color-border); }
  .end { display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem; }
  .line-total { font-weight: 600; }
  .remove { background: none; border: 0; color: var(--color-danger); font-size: 0.85rem; cursor: pointer; }
  .cart-side { padding: 1.5rem; position: sticky; top: 5rem; display: grid; gap: 0.85rem; }
  .totals { display: grid; gap: 0.4rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--color-border); }
  .row { display: flex; justify-content: space-between; }
  .total { font-weight: 700; font-size: 1.15rem; }
  .checkout { width: 100%; }
</style>
