---
import type { SiteConfig } from "../lib/site-config";
interface Props { site: SiteConfig; }
const { site } = Astro.props;
---
<section class="section">
  <div class="container contact-grid">
    <div>
      <h2>Get in touch</h2>
      <p class="muted">Questions about an order or product? We'd love to hear from you. Email us — we respond within one business day.</p>
      <ul class="contact-list">
        <li><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li>
          <strong>Address:</strong>
          <address>
            {site.address.line1}{site.address.line2 ? `, ${site.address.line2}` : ""}<br />
            {site.address.city}, {site.address.region} {site.address.postalCode}<br />
            {site.address.country}
          </address>
        </li>
        {site.hours && <li><strong>Hours:</strong> {site.hours}</li>}
      </ul>
    </div>
    <div class="card contact-card">
      <h3>Send a message</h3>
      <p class="muted small">Or email us directly — we usually respond within one business day.</p>
      <a href={`mailto:${site.email}?subject=Inquiry from website`} class="btn btn-primary">Email {site.siteName}</a>
    </div>
  </div>
</section>
<style>
  .contact-grid {
    display: grid; gap: 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 800px) { .contact-grid { grid-template-columns: 1.3fr 1fr; align-items: start; } }
  .contact-list { list-style: none; padding: 0; margin: 1.25rem 0; display: grid; gap: 0.85rem; word-break: break-word; }
  .contact-list a { word-break: break-all; }
  address { font-style: normal; }
  .contact-card { padding: 1.75rem; display: grid; gap: 0.85rem; }
</style>
