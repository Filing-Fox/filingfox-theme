---
import type { SiteConfig } from "../lib/site-config";
interface Props { site: SiteConfig; }
const { site } = Astro.props;
---
<section class="section">
  <div class="container checkout-grid">
    <form class="checkout-form card" id="ff-checkout-form" novalidate>
      <h1>Checkout</h1>
      <p class="muted">Submit your order and {site.siteName} will contact you to confirm details.</p>

      <fieldset>
        <legend>Contact</legend>
        <div class="row">
          <div>
            <label class="label" for="name">Full name *</label>
            <input class="input" id="name" name="name" type="text" required autocomplete="name" />
          </div>
          <div>
            <label class="label" for="email">Email *</label>
            <input class="input" id="email" name="email" type="email" required autocomplete="email" />
          </div>
        </div>
        <div class="row">
          <div>
            <label class="label" for="phone">Phone *</label>
            <input class="input" id="phone" name="phone" type="tel" required autocomplete="tel" />
          </div>
        </div>
      </fieldset>

      <fieldset>
        <legend>Shipping Address</legend>
        <div>
          <label class="label" for="address1">Address line 1 *</label>
          <input class="input" id="address1" name="address1" type="text" required autocomplete="address-line1" />
        </div>
        <div>
          <label class="label" for="address2">Address line 2</label>
          <input class="input" id="address2" name="address2" type="text" autocomplete="address-line2" />
        </div>
        <div class="row">
          <div>
            <label class="label" for="city">City *</label>
            <input class="input" id="city" name="city" type="text" required autocomplete="address-level2" />
          </div>
          <div>
            <label class="label" for="region">State / Region *</label>
            <input class="input" id="region" name="region" type="text" required autocomplete="address-level1" />
          </div>
        </div>
        <div class="row">
          <div>
            <label class="label" for="postal">Postal code *</label>
            <input class="input" id="postal" name="postalCode" type="text" required autocomplete="postal-code" />
          </div>
          <div>
            <label class="label" for="country">Country *</label>
            <input class="input" id="country" name="country" type="text" required autocomplete="country-name" value="USA" />
          </div>
        </div>
        <div>
          <label class="label" for="notes">Order notes</label>
          <textarea class="textarea" id="notes" name="notes" rows="3"></textarea>
        </div>
      </fieldset>

      <div class="turnstile-wrap">
        <div
          class="cf-turnstile"
          data-sitekey={site.orders.turnstileSiteKey}
          data-callback="ffOnTurnstile"
        ></div>
      </div>

      <p class="error" id="ff-checkout-error" style="display:none"></p>

      <button type="submit" class="btn btn-primary submit-btn" id="ff-checkout-submit">
        <span class="submit-label">Place Order</span>
      </button>
      <p class="muted small">Your order will be emailed to {site.siteName}. No payment is collected here.</p>
    </form>

    <aside class="order-summary card">
      <h2>Order Summary</h2>
      <div data-cart-empty>
        <p class="muted">Your cart is empty. <a href="/products">Browse products</a>.</p>
      </div>
      <div data-cart-body style="display:none">
        <ul class="lines" data-cart-lines data-cart-line-template="#tpl-summary-line"></ul>
        <div class="totals">
          <div class="totals-row"><span>Subtotal</span><span data-cart-subtotal>—</span></div>
          <div class="totals-row total"><span>Total</span><span data-cart-subtotal>—</span></div>
        </div>
      </div>
    </aside>
  </div>
</section>

<template id="tpl-summary-line">
  <li class="summary-line">
    <img data-cart-slot="image" width="48" height="48" alt="" />
    <div class="summary-info">
      <span class="summary-name" data-cart-slot="name"></span>
      <span class="muted small" data-cart-slot="qty"></span>
    </div>
    <span class="summary-price" data-cart-slot="price"></span>
  </li>
</template>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script define:vars={{
  domain: site.domain,
  currency: site.currency,
  workerUrl: site.orders.workerUrl,
  siteEmail: site.email,
}}>
  (function () {
    let turnstileToken = "";
    window.ffOnTurnstile = (token) => { turnstileToken = token; };

    const form = document.getElementById("ff-checkout-form");
    const submit = document.getElementById("ff-checkout-submit");
    const errEl = document.getElementById("ff-checkout-error");
    if (!form || !submit || !errEl) return;

    function showError(msg) {
      errEl.textContent = msg;
      errEl.style.display = msg ? "" : "none";
    }

    form.addEventListener("submit", async (ev) => {
      ev.preventDefault();
      showError("");
      const cart = window.ffCart;
      if (!cart || cart.items.length === 0) { showError("Your cart is empty."); return; }
      if (!turnstileToken) { showError("Please complete the captcha."); return; }

      const fd = new FormData(form);
      const customer = {};
      for (const [k, v] of fd.entries()) customer[k] = String(v).trim();
      const required = ["name","email","phone","address1","city","region","postalCode","country"];
      for (const k of required) {
        if (!customer[k]) { showError("Please fill all required fields."); return; }
      }

      const items = cart.items.map((i) => ({
        slug: i.slug, name: i.name, sku: i.sku, price: i.price, qty: i.qty, image: i.image,
      }));
      const sub = items.reduce((s, i) => s + i.price * i.qty, 0);
      const payload = {
        domain,
        currency,
        items,
        subtotal: Math.round(sub * 100) / 100,
        customer,
        turnstileToken,
      };

      submit.disabled = true;
      submit.querySelector(".submit-label").textContent = "Sending…";
      try {
        const res = await fetch(workerUrl.replace(/\/$/, "") + "/order", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
          mode: "cors",
          credentials: "omit",
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.ok) {
          showError(data.error || ("Failed (" + res.status + "). Try again or email " + siteEmail + "."));
          submit.disabled = false;
          submit.querySelector(".submit-label").textContent = "Place Order";
          return;
        }
        cart.clear();
        location.href = "/thank-you?ref=" + encodeURIComponent(data.ref || "");
      } catch (e) {
        showError("Network error. Try again or email " + siteEmail + ".");
        submit.disabled = false;
        submit.querySelector(".submit-label").textContent = "Place Order";
      }
    });
  })();
</script>
<style>
  .checkout-grid { display: grid; gap: 2rem; grid-template-columns: 1fr; }
  @media (min-width: 900px) { .checkout-grid { grid-template-columns: 1.4fr 1fr; align-items: start; } }
  .checkout-form { padding: 1.75rem; display: grid; gap: 1.25rem; }
  .checkout-form fieldset { border: 0; padding: 0; margin: 0; display: grid; gap: 0.85rem; }
  .checkout-form legend { font-weight: 600; font-size: 1.05rem; margin-bottom: 0.35rem; padding: 0; }
  .row { display: grid; gap: 0.85rem; grid-template-columns: 1fr 1fr; }
  @media (max-width: 580px) { .row { grid-template-columns: 1fr; } }
  .error { color: var(--color-danger); font-weight: 500; }
  .submit-btn { width: 100%; padding: 0.95rem; font-size: 1.05rem; }
  .order-summary { padding: 1.5rem; position: sticky; top: 5rem; }
  .lines { list-style: none; margin: 0; padding: 0; }
  .summary-line {
    display: grid; grid-template-columns: 48px 1fr auto; gap: 0.75rem;
    align-items: center; padding: 0.6rem 0; border-bottom: 1px solid var(--color-border);
  }
  .summary-line img { border-radius: var(--radius); object-fit: cover; aspect-ratio: 1; }
  .summary-info { display: flex; flex-direction: column; min-width: 0; }
  .summary-name { font-size: 0.9rem; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .summary-price { font-weight: 600; font-size: 0.95rem; }
  .totals { margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--color-border); display: grid; gap: 0.4rem; }
  .totals-row { display: flex; justify-content: space-between; }
  .totals-row.total { font-weight: 700; font-size: 1.15rem; padding-top: 0.4rem; border-top: 1px solid var(--color-border); }
  .turnstile-wrap { display: flex; justify-content: center; }
</style>
