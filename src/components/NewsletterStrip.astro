---
import type { SiteConfig } from "../lib/site-config";
interface Props { site: SiteConfig; }
const { site } = Astro.props;
---
<section class="newsletter">
  <div class="container nl-grid">
    <div class="nl-copy">
      <h2>Get 10% off your first order</h2>
      <p>Join our newsletter for product drops, sales, and styling tips. No spam, ever.</p>
    </div>
    <form class="nl-form" action={`mailto:${site.email}?subject=Newsletter signup`} method="post" enctype="text/plain">
      <label class="sr-only" for="nl-email">Email</label>
      <input type="email" id="nl-email" name="email" placeholder="your@email.com" required class="nl-input" />
      <button type="submit" class="btn btn-primary nl-submit">Subscribe →</button>
    </form>
  </div>
</section>
<style>
  .newsletter {
    background: var(--color-primary);
    color: var(--color-primary-fg);
    padding: 3rem 0;
  }
  .nl-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
    align-items: center;
  }
  @media (min-width: 760px) {
    .nl-grid { grid-template-columns: 1.1fr 1fr; }
  }
  .nl-copy h2 { color: var(--color-primary-fg); margin: 0 0 0.5rem; }
  .nl-copy p { color: rgba(255,255,255,0.75); margin: 0; }
  .nl-form { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .nl-input {
    flex: 1;
    min-width: 200px;
    padding: 0.85rem 1rem;
    border-radius: var(--radius);
    border: 0;
    background: white;
    color: var(--color-fg);
    font: inherit;
  }
  .nl-input:focus { outline: 3px solid var(--color-accent); outline-offset: 1px; }
  .nl-submit { padding: 0.85rem 1.4rem; background: var(--color-accent); }
  .nl-submit:hover { filter: brightness(1.1); }
  .sr-only { position: absolute; left: -9999px; }
</style>
