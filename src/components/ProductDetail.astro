---
import type { Product } from "../lib/select-products";
import type { Currency } from "../lib/site-config";
import { currencyFormatter } from "../lib/site-config";

interface Props {
  product: Product;
  currency: Currency;
}
const { product, currency } = Astro.props;
const fmt = currencyFormatter(currency);
const onSale = product.compareAtPrice && product.compareAtPrice > product.price;
const productJson = JSON.stringify({
  slug: product.slug,
  name: product.name,
  sku: product.sku,
  price: product.price,
  image: product.images[0],
});
---
<section class="section">
  <div class="container product-detail" x-data="{ qty: 1 }">
    <div class="gallery">
      <img class="main" src={product.images[0]} alt={product.name} width="900" height="900" />
      {product.images.length > 1 && (
        <div class="thumbs">
          {product.images.slice(0, 4).map((src, i) => (
            <img src={src} alt={`${product.name} view ${i + 1}`} loading="lazy" />
          ))}
        </div>
      )}
    </div>
    <div class="info">
      <span class="badge">{product.category}</span>
      <h1>{product.name}</h1>
      <p class="muted">SKU: {product.sku}</p>
      <div class="price-row">
        <span class="price-big">{fmt.format(product.price)}</span>
        {onSale && product.compareAtPrice && <span class="strike">{fmt.format(product.compareAtPrice)}</span>}
      </div>
      <p class="short-desc">{product.shortDesc}</p>
      <div class="qty-row">
        <label class="label" for="qty">Quantity</label>
        <input class="input qty-input" id="qty" type="number" min="1" max="99" x-model.number="qty" />
        <button
          type="button"
          class="btn btn-primary"
          data-product={productJson}
          @click={`$store.cart.add(JSON.parse($el.dataset.product), qty)`}
        >
          Add to Cart
        </button>
      </div>
      <details class="details-block">
        <summary>Description</summary>
        <div class="markdown" set:html={product.longDescMd.replace(/\n/g, "<br>")}></div>
      </details>
      <details class="details-block">
        <summary>Specifications</summary>
        <table class="specs">
          <tbody>
            {Object.entries(product.specs).map(([k, v]) => (
              <tr><th>{k}</th><td>{v}</td></tr>
            ))}
          </tbody>
        </table>
      </details>
    </div>
  </div>
</section>
<style>
  .product-detail {
    display: grid; gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 800px) { .product-detail { grid-template-columns: 1fr 1fr; } }
  .gallery .main { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: var(--radius-lg); }
  .thumbs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem; margin-top: 0.75rem; }
  .thumbs img { aspect-ratio: 1; object-fit: cover; border-radius: var(--radius); }
  .price-big { font-size: 2rem; font-weight: 700; }
  .price-row { display: flex; gap: 0.75rem; align-items: baseline; margin: 0.75rem 0 1rem; }
  .short-desc { color: var(--color-fg-muted); margin-bottom: 1.25rem; }
  .qty-row { display: flex; gap: 0.75rem; align-items: flex-end; margin-bottom: 1.5rem; }
  .qty-input { width: 80px; }
  .details-block { border-top: 1px solid var(--color-border); padding: 1rem 0; }
  .details-block summary { font-weight: 600; cursor: pointer; }
  .specs { width: 100%; margin-top: 0.75rem; border-collapse: collapse; }
  .specs th, .specs td { text-align: left; padding: 0.5rem 0; border-bottom: 1px solid var(--color-border); }
  .specs th { color: var(--color-fg-muted); font-weight: 500; width: 40%; }
</style>
