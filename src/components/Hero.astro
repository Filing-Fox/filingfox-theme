---
import type { SiteConfig } from "../lib/site-config";
interface Props {
  site: SiteConfig;
  eyebrow?: string;
  headline?: string;
  sub?: string;
  ctaHref?: string;
  ctaLabel?: string;
  image?: string;
  secondaryCtaHref?: string;
  secondaryCtaLabel?: string;
}
const {
  site,
  eyebrow = "New season collection",
  headline = `Welcome to ${site.siteName}`,
  sub = site.description,
  ctaHref = "/products",
  ctaLabel = "Shop the collection",
  image,
  secondaryCtaHref = "/about",
  secondaryCtaLabel = "Learn more",
} = Astro.props;
---
<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h1>{headline}</h1>
      <p class="lead">{sub}</p>
      <div class="cta-row">
        <a href={ctaHref} class="btn btn-primary cta-primary">{ctaLabel} <span aria-hidden="true">→</span></a>
        <a href={secondaryCtaHref} class="btn-secondary">{secondaryCtaLabel}</a>
      </div>
      <ul class="hero-bullets">
        <li><span class="dot" aria-hidden="true">✓</span> Free shipping over $50</li>
        <li><span class="dot" aria-hidden="true">✓</span> 30-day easy returns</li>
        <li><span class="dot" aria-hidden="true">✓</span> Secure checkout</li>
      </ul>
    </div>
    {image && (
      <div class="hero-image">
        <img src={image} alt="" loading="eager" decoding="async" />
        <span class="floating-badge">Top rated 4.7 ★</span>
      </div>
    )}
  </div>
</section>
<style>
  .hero {
    background: linear-gradient(135deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    padding: 4rem 0 4.5rem;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    align-items: center;
  }
  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 1rem;
    font-weight: 700;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
  }
  .hero h1 { font-size: clamp(2.1rem, 4.5vw, 3.6rem); margin-bottom: 1rem; letter-spacing: -0.02em; }
  .lead { font-size: 1.18rem; color: var(--color-fg-muted); max-width: 52ch; margin-bottom: 1.75rem; line-height: 1.55; }
  .cta-row { display: flex; gap: 0.85rem; align-items: center; flex-wrap: wrap; margin-bottom: 1.75rem; }
  .cta-primary { padding: 0.95rem 1.6rem; font-size: 1.02rem; }
  .btn-secondary {
    color: var(--color-fg);
    text-decoration: none;
    font-weight: 600;
    padding: 0.95rem 0.6rem;
    border-bottom: 2px solid var(--color-fg);
    transition: opacity 0.15s;
  }
  .btn-secondary:hover { opacity: 0.7; }
  .hero-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    color: var(--color-fg-muted);
    font-size: 0.92rem;
  }
  .hero-bullets li { display: inline-flex; align-items: center; gap: 0.4rem; }
  .dot {
    display: inline-grid;
    place-items: center;
    width: 18px; height: 18px;
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
    color: var(--color-accent);
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
  }
  .hero-image { position: relative; }
  .hero-image img {
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 50px rgba(0,0,0,0.12);
    width: 100%;
    aspect-ratio: 1.05;
    object-fit: cover;
    background: white;
  }
  .floating-badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    background: white;
    padding: 0.55rem 0.95rem;
    border-radius: 999px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.12);
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--color-fg);
  }
  @media (min-width: 880px) {
    .hero-grid { grid-template-columns: 1.05fr 1fr; }
  }
</style>
